const chapters = require("../data/chapters.json");

/**
 * Finds a chapter by id across all subjects/branches and returns
 * its title plus the subject/branch labels for context.
 */
function findChapter(chapterId) {
  for (const [subjectKey, subject] of Object.entries(chapters)) {
    for (const [branchKey, branch] of Object.entries(subject.branches)) {
      const match = branch.chapters.find((c) => c.id === chapterId);
      if (match) {
        return {
          subject: subject.label,
          branch: branch.label,
          chapter: match.title,
          chapterId: match.id
        };
      }
    }
  }
  return null;
}

/**
 * Builds a system instruction that locks the AI to one chapter only.
 * Every route (tutor, notes, flashcards, etc.) reuses this so the
 * "stay on this chapter" rule is consistent everywhere.
 */
function buildChapterLockPrompt(chapterId, roleDescription) {
  const info = findChapter(chapterId);
  if (!info) {
    throw new Error("Unknown chapterId: " + chapterId);
  }

  return {
    info,
    systemInstruction: `You are a CBSE Class 10 ${info.subject} (${info.branch}) teacher, ${roleDescription}
You are ONLY allowed to discuss the chapter "${info.chapter}" from the NCERT Class 10 ${info.branch} textbook.
If the student asks about any other chapter or subject, politely tell them to go back and select the correct chapter instead of answering.
Base your answers on NCERT Class 10 concepts for the 2026-2027 academic year. Keep explanations simple, exam-focused, and structured with bullet points where useful.`
  };
}

module.exports = { findChapter, buildChapterLockPrompt };
